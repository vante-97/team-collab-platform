# ========================================
#  环境变量配置说明
#  复制此文件为 .env.local（前端）或 backend/.env（后端）
# ========================================

# ---- 前端 ----
# API 地址（前后端分离时的后端地址）
NEXT_PUBLIC_API_URL=http://localhost:5000

# ---- 后端安全配置 ----
# 生产环境务必设置以下环境变量，否则每次重启密钥都会变化导致所有用户 Token 失效
# SECRET_KEY=你的随机密钥（至少32位）
# JWT_SECRET_KEY=你的JWT随机密钥（至少32位）
# FLASK_DEBUG=false  # 生产环境设为 false

# ---- CORS 跨域配置 ----
# 生产部署时设置前端域名，多个用逗号分隔
# CORS_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

# ========================================
#  部署平台配置
# ========================================

# --- Vercel（前端） ---
# 1. 导入 GitHub 仓库
# 2. Framework 选择 Next.js
# 3. 环境变量: NEXT_PUBLIC_API_URL = 你的后端地址
# 4. 自动部署（每次 push 触发）

# --- Railway / Render（后端） ---
# 1. 设置 Root Directory = backend
# 2. Build Command: pip install -r requirements.txt
# 3. Start Command: gunicorn app:app --bind 0.0.0.0:$PORT
# 4. 环境变量: SECRET_KEY, JWT_SECRET_KEY, CORS_ORIGINS, FLASK_DEBUG=false
